# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/kritiva

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES=7d

# Default admin (used once by `npm run seed:admin`)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
ADMIN_EMAIL=kritivaproductions@gmail.com

# SMTP (e.g. Hostinger mail, Gmail app password, etc.)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_smtp_password
MAIL_FROM_NAME=Kritiva Productions
MAIL_FROM_EMAIL=info@yourdomain.com

# Notify this inbox whenever a new booking comes in
ADMIN_NOTIFY_EMAIL=kritivaproductions@gmail.com

# Public site URL (used in email templates / links)
SITE_URL=https://yourdomain.com

# CORS - comma separated allowed origins
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# Cloudinary (image uploads: banners, event covers, profile photos, hero background).
# Without these set, image uploads fall back to local disk (server/uploads/*),
# which does NOT survive redeploys on hosts with ephemeral storage (this was
# the root cause of banners disappearing after every deploy).
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
